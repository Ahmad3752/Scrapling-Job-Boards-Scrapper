# Path to master skill list Excel file
EXCEL_SKILL_GAP=data/skills_master.xlsx

# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scraper Redis URL only. DevLens must use a separate DEVLENS_REDIS_URL in its own backend.
# Upstash: use rediss:// with double-s for TLS.
SCRAPER_REDIS_URL=rediss://default:your_password@your-scraper-endpoint.upstash.io:6379
REDIS_MAX_RETRIES=3
SCRAPER_REDIS_SEEN_TTL=86400
SCRAPER_REDIS_STATS_TTL=86400
SCRAPER_TRIGGER_LOCK_TTL_SECONDS=43200

# Scraping limits
JOB_SCRAPING_BOARDS=linkedin,indeed,rozee,mustakbil
JOB_SCRAPING_MAX_PAGES_PER_BOARD=1
JOB_SCRAPING_MAX_JOBS_PER_BOARD=15
JOB_SCRAPING_DOWNLOAD_DELAY=2.0
JOB_SCRAPING_FETCH_TIMEOUT_MS=60000

# Number of parallel workers for role scraping
JOB_SCRAPING_WORKERS=2

# Days after which a scraped job is marked inactive, not deleted
JOB_STALE_AFTER_DAYS=7

# Canonical DevLens scraper role keys. Country is always Pakistan.
SCRAPER_ROLE_KEYS=backend,frontend,full_stack,mobile,ai_ml,devops,data_engineer,qa_automation

# Optional legacy allowlist for interactive scout flows. Defaults to canonical DevLens labels.
PERMITTED_ROLES=["Backend Developer","Frontend Developer","Full Stack Developer","Mobile Developer","AI/ML Engineer","DevOps Engineer","Data Engineer","QA Automation Engineer"]
